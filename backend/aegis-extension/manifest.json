{
  "manifest_version": 3,
  "name": "AEGIS Guard",
  "version": "1.0.0",
  "description": "Grammarly for sensitive data — real-time PII protection on ChatGPT, Claude, Gemini, Copilot",
  "permissions": ["storage", "activeTab", "tabs", "notifications"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:*/",
    "http://127.0.0.1:*/",
    "https://chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://copilot.microsoft.com/*",
    "https://www.bing.com/*",
    "https://chat.openai.com/*",
    "https://openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://copilot.microsoft.com/*",
        "https://www.bing.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AEGIS Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "commands": {
    "reanalyze": {
      "suggested_key": { "default": "Alt+Shift+R" },
      "description": "Force re-analyze prompt"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
